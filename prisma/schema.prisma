datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// NextAuth models required by Prisma Adapter
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  quizzes       Quiz[]
  summaries     Summary[]
  flashcards    FlashcardSet[]
  chatMessages  ChatMessage[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom study models
model Quiz {
  id            String   @id @default(cuid())
  userId        String
  title         String
  prompt        String
  questionsJson String   // Store stringified array of questions
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Summary {
  id               String   @id @default(cuid())
  userId           String
  title            String
  prompt           String
  executiveSummary String
  keyPointsJson    String   // Store stringified array of bullet points
  conclusion       String
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FlashcardSet {
  id        String   @id @default(cuid())
  userId    String
  title     String
  prompt    String
  cardsJson String   // Store stringified array of flashcards (question/answer)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // 'user', 'assistant', 'error'
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
